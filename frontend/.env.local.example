# KiraNA — Environment Variables
# Copy this file to .env.local and fill in your values

# ─── Supabase ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ─── Backend API ─────────────────────────────────────────────────────────────
# Leave blank to use mock mode (no backend required)
NEXT_PUBLIC_API_BASE_URL=

# ─── Mock Mode ───────────────────────────────────────────────────────────────
# Set to "true" to bypass real API calls and use simulated data
# Automatically enabled when NEXT_PUBLIC_API_BASE_URL is empty
NEXT_PUBLIC_MOCK_MODE=true
